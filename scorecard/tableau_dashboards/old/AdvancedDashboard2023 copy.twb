              <calculation class='tableau' formula='IF { FIXED : PERCENTILE([Selected Scorecard Index (copy)_4544061701455785985], 0.25) } &gt;= [Selected Scorecard Index (copy)_4544061701455785985] THEN&#10;    &quot;Q1&quot;&#10;ELSEIF { FIXED : PERCENTILE([Selected Scorecard Index (copy)_4544061701455785985], 0.5) } &gt;= [Selected Scorecard Index (copy)_4544061701455785985] THEN&#10;    &quot;Q2&quot;&#10;ELSEIF { FIXED : PERCENTILE([Selected Scorecard Index (copy)_4544061701455785985], 0.75) } &gt;= [Selected Scorecard Index (copy)_4544061701455785985] THEN&#10;    &quot;Q3&quot;&#10;ELSE&#10;    &quot;Q4&quot;&#10;END' />
