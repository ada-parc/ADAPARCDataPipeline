            <column datatype='real' name='[Affordable Housing Score]' role='measure' type='quantitative' />
            <column caption='Work Economic Indices Quartiles' datatype='string' name='[Community Living Index Quartiles (copy)_165436971421515782]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF { FIXED : PERCENTILE([Selected Scorecard Index (copy)_165436971168505857], 0.25) } &gt;= [Selected Scorecard Index (copy)_165436971168505857] THEN&#10;    &quot;Q1&quot;&#10;ELSEIF { FIXED : PERCENTILE([Selected Scorecard Index (copy)_165436971168505857], 0.5) } &gt;= [Selected Scorecard Index (copy)_165436971168505857] THEN&#10;    &quot;Q2&quot;&#10;ELSEIF { FIXED : PERCENTILE([Selected Scorecard Index (copy)_165436971168505857], 0.75) } &gt;= [Selected Scorecard Index (copy)_165436971168505857] THEN&#10;    &quot;Q3&quot;&#10;ELSE&#10;    &quot;Q4&quot;&#10;END' />
            </column>
            <column datatype='real' name='[Employment and Income]' role='measure' type='quantitative' />
            <column datatype='real' name='[Living in Community Score]' role='measure' type='quantitative' />
            <column datatype='real' name='[Poverty and Lack of Work]' role='measure' type='quantitative' />
            <column caption='Selected Work Economic Index' datatype='real' name='[Selected Community Living Index (copy)_165436971421904904]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Select Community Participation Index (copy)_165436971421597703]&#10;  WHEN &quot;Poverty and Lack of Work&quot; THEN [Employment and Income]&#10;  WHEN &quot;Employment and Income&quot; THEN [Poverty and Lack of Work]&#10;END' />
            </column>
            <column caption='Selected Community Living Index' datatype='real' name='[Selected Scorecard Index (copy)_165436971168505857]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Select Scorecard Index (copy)_165436971166470144]&#10;  WHEN &quot;Living in Community&quot; THEN [Living in Community Score]&#10;  WHEN &quot;Affordable Housing&quot; THEN [Affordable Housing Score]&#10;END' />
            </column>
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column-instance column='[Community Living Index Quartiles (copy)_165436971421515782]' derivation='None' name='[none:Community Living Index Quartiles (copy)_165436971421515782:nk]' pivot='key' type='nominal' />
            <column-instance column='[State]' derivation='None' name='[none:State:nk]' pivot='key' type='nominal' />
