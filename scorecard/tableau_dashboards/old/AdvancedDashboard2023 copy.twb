          <datasource-dependencies datasource='federated.17l2xbt0054ey615kwrfw1xyth03'>
            <column caption='Community Participation Index Quartiles' datatype='string' name='[Community Living Index Quartiles (copy)_165436971419217925]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF { FIXED : PERCENTILE([Selected Community Living Index (copy)_165436971418624004], 0.25) } &gt;= [Selected Community Living Index (copy)_165436971418624004] THEN&#10;    &quot;Q1&quot;&#10;ELSEIF { FIXED : PERCENTILE([Selected Community Living Index (copy)_165436971418624004], 0.5) } &gt;= [Selected Community Living Index (copy)_165436971418624004] THEN&#10;    &quot;Q2&quot;&#10;ELSEIF { FIXED : PERCENTILE([Selected Community Living Index (copy)_165436971418624004], 0.75) } &gt;= [Selected Community Living Index (copy)_165436971418624004] THEN&#10;    &quot;Q3&quot;&#10;ELSE&#10;    &quot;Q4&quot;&#10;END' />
            </column>
            <column datatype='real' name='[Education Score]' role='measure' type='quantitative' />
            <column datatype='real' name='[Insurance Score]' role='measure' type='quantitative' />
            <column caption='Selected Community Participation Index' datatype='real' name='[Selected Community Living Index (copy)_165436971418624004]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Select Community Living Index (copy)_165436971418132483]&#10;  WHEN &quot;Tech Access Index&quot; THEN [Tech Access Score]&#10;  WHEN &quot;Insurance Access Index&quot; THEN [Insurance Score]&#10;  WHEN &quot;Education Access Index&quot; THEN [Education Score]&#10;  WHEN &quot;Transportation Access Index&quot; THEN  [Transportation Score]&#10;END' />
            </column>
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column datatype='real' name='[Tech Access Score]' role='measure' type='quantitative' />
            <column datatype='real' name='[Transportation Score]' role='measure' type='quantitative' />
            <column-instance column='[Community Living Index Quartiles (copy)_165436971419217925]' derivation='None' name='[none:Community Living Index Quartiles (copy)_165436971419217925:nk]' pivot='key' type='nominal' />
            <column-instance column='[State]' derivation='None' name='[none:State:nk]' pivot='key' type='nominal' />
            <column-instance column='[Selected Community Living Index (copy)_165436971418624004]' derivation='Sum' name='[sum:Selected Community Living Index (copy)_165436971418624004:qk]' pivot='key' type='quantitative' />
