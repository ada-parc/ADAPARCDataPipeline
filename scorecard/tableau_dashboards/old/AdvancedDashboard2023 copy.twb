            <column caption='Select Community Living Index' datatype='string' name='[Select Scorecard Index (copy)_165436971166470144]' param-domain-type='list' role='measure' type='nominal' value='&quot;Living in Community&quot;'>
              <calculation class='tableau' formula='&quot;Living in Community&quot;' />
            </column>
          </datasource-dependencies>
